# NOTE: Keep in sync with CFLAGS + CFLAGS_DEBUG in the Makefile
CompileFlags:
  Add:
    - -xc # only required for the language server
    - -std=c99
    - -Wall
    - -Wextra
    - -Wpedantic
    - -Wno-char-subscripts
    - -Wno-parentheses
    - -Wimplicit-fallthrough
    - -Werror=incompatible-pointer-types
    - -DHAMMER_DEBUG
