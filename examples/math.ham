let assert_eq a b = if a == b
  then return ()
  else error ("assertion failed: " ++ (repr a) ++ " == " ++ (repr b));

--

assert_eq (1 + 2 * 9 / 3 - 2) 5;

let rem x y = x - x / y * y;
assert_eq (0 `rem 1) 0;
assert_eq (1 `rem 1) 0;
assert_eq (1 `rem 2) 1;
assert_eq (15 `rem 4) 3;

print "passed";
