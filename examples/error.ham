let assert_eq a b = if a == b
  then return ()
  else error ("assertion failed: " ++ (repr a) ++ " == " ++ (repr b));

assert_eq () ();
assert_eq (1,) (1,);
assert_eq (1, 2) (1, 2);
assert_eq [] [];
assert_eq [1] [1];
assert_eq [1, 2] [1, 2];
assert_eq 42 42;
assert_eq "" "";
assert_eq "foo" "foo";

print "passed";
